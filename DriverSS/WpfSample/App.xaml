<!--
============================================================
App.xaml — Điểm khởi động ứng dụng WPF
============================================================
StartupUri trỏ đến MainWindow.xaml — cửa sổ chính sẽ mở khi app khởi động.
Để dùng custom startup logic (như khởi tạo drivers), xem App.xaml.cs.
============================================================
-->
<Application x:Class="WpfSample.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">

    <Application.Resources>
        <!-- Global styles có thể thêm ở đây -->
        <ResourceDictionary>

            <!-- Style mặc định cho các Label trạng thái -->
            <Style x:Key="StatusLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Margin" Value="4,0"/>
            </Style>

            <!-- Style cho TextBox hiển thị giá trị -->
            <Style x:Key="ValueTextBox" TargetType="TextBox">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Padding" Value="6,4"/>
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="Background" Value="#F5F5F5"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>

</Application>
